      "Bash(curl -s -X OPTIONS http://localhost:3001/api/login -H 'Origin: file://' -H 'Access-Control-Request-Method: POST' -H 'Access-Control-Request-Headers: Content-Type,Authorization' -I)",
      "Bash(curl -s -X POST http://localhost:3001/api/login -H 'Content-Type: application/json' -H 'Origin: null' -d '{\"email\":\"teste@teste.com\",\"password\":\"123456\"}' -I)",
